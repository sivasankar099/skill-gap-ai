# SkillGap AI — Backend environment variables
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# Spring Boot reads OS environment variables automatically.
# Load this file before starting the server (PowerShell):
#   Get-Content .env | ForEach-Object {
#     if ($_ -match '^\s*([^#=]+)=(.*)$') {
#       Set-Item -Path "env:$($matches[1].Trim())" -Value $matches[2].Trim()
#     }
#   }

# --- Server ---
SERVER_PORT=8080

# --- MySQL Database ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/skillgap_db?createDatabaseIfNotExist=true&allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- JWT Authentication ---
JWT_SECRET=generate_a_long_random_secret_at_least_64_characters_for_hs512_signing
JWT_EXPIRATION_MS=86400000

# --- Google Gemini API (required for resume parsing & analysis) ---
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models

# --- Qdrant Vector Database (optional for local dev) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- CORS (frontend origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
